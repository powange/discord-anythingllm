# Token du bot Discord (Developer Portal > votre application > Bot > Reset Token)
DISCORD_TOKEN=

# URL de l'instance AnythingLLM, SANS slash final (ex: https://llm.exemple.com)
ANYTHINGLLM_URL=

# Clé API AnythingLLM (Settings > Tools > Developer API > Generate New API Key)
ANYTHINGLLM_API_KEY=

# Slug du workspace AnythingLLM (visible dans l'URL du workspace, ex: mon-workspace)
ANYTHINGLLM_WORKSPACE=

# Mode de requête : "chat" (conversationnel) ou "query" (strictement factuel). Défaut: chat
# NB: "agent" n'est PAS une valeur valide ici — voir ANYTHINGLLM_AGENT ci-dessous.
ANYTHINGLLM_MODE=chat

# Optionnel : "true" pour préfixer chaque question par "@agent" et déclencher
# les skills/tools/MCP de l'agent AnythingLLM via la Developer API. Défaut: false.
# (ANYTHINGLLM_MODE reste chat/query ; alternative : régler l'agent dans le workspace.)
ANYTHINGLLM_AGENT=false

# Optionnel : IDs de salons (séparés par des virgules) où le bot répond à TOUS les messages.
# Laisser vide pour ne répondre que sur mention (@bot) et en message privé.
ALLOWED_CHANNEL_IDS=
